---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Sabor Argentino - Auténticas recetas de la gastronomía de Argentina." />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	:root {
		--primary: #5BC0EB;
		--secondary: #FDE74C;
		--bg-dark: #0A0F16;
		--card-bg: rgba(255, 255, 255, 0.05);
		--text-main: #E2E8F0;
		--text-muted: #94A3B8;
	}
	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}
	html {
		font-family: 'Outfit', sans-serif;
		background: var(--bg-dark);
		color: var(--text-main);
	}
	body {
		min-height: 100vh;
		background: radial-gradient(circle at top right, rgba(91, 192, 235, 0.15), transparent 40%),
					radial-gradient(circle at bottom left, rgba(253, 231, 76, 0.1), transparent 40%);
	}
	html {
		scroll-behavior: smooth;
	}
</style>
