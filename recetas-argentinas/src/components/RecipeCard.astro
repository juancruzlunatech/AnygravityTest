---
interface Props {
    recipe: any;
    lang?: 'es' | 'en';
}

const { recipe, lang = 'es' } = Astro.props;
const data = recipe[lang];
const link = lang === 'en' ? `/en/recetas/${recipe.id}` : `/recetas/${recipe.id}`;
const actionText = lang === 'en' ? 'View full recipe &rarr;' : 'Ver receta completa &rarr;';
---

<article class="recipe-card">
	<a href={link} class="card-link">
		<div class="image-wrapper">
			<img src={recipe.image} alt={data.title} loading="lazy" transition:name={`img-${recipe.id}`} />
		</div>
		<div class="content">
			<h3 transition:name={`title-${recipe.id}`}>{data.title}</h3>
			<p>{data.description}</p>
			<div class="meta">
				<span>⏱ {data.time}</span>
				<span>🔥 {data.difficulty}</span>
			</div>
			
			<div class="action-btn">
			    {actionText}
			</div>
		</div>
	</a>
</article>

<style>
	.recipe-card {
		background: var(--card-bg);
		border-radius: 20px;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.08);
		transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
		backdrop-filter: blur(10px);
		display: flex;
		flex-direction: column;
	}
	
	.card-link {
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.recipe-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
		border-color: rgba(91, 192, 235, 0.4);
	}

	.image-wrapper {
		width: 100%;
		height: 220px;
		overflow: hidden;
	}

	.image-wrapper img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.recipe-card:hover .image-wrapper img {
		transform: scale(1.05);
	}

	.content {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		flex-grow: 1;
	}

	h3 {
		font-size: 1.5rem;
		font-weight: 600;
		color: #ffffff;
		margin-bottom: 0.5rem;
		transition: color 0.3s ease;
	}
	
	.recipe-card:hover h3 {
		color: var(--primary);
	}

	p {
		color: var(--text-muted);
		font-size: 0.95rem;
		line-height: 1.5;
		margin-bottom: 1.5rem;
		flex-grow: 1;
	}

	.meta {
		display: flex;
		justify-content: space-between;
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--text-main);
		padding-top: 1rem;
		border-top: 1px solid rgba(255,255,255,0.05);
		margin-bottom: 1rem;
	}
	
	.action-btn {
	    font-size: 0.9rem;
	    font-weight: 600;
	    color: var(--primary);
	    text-align: right;
	    margin-top: auto;
	    transition: transform 0.2s ease;
	}
	
	.recipe-card:hover .action-btn {
	    transform: translateX(3px);
	    color: var(--secondary);
	}
</style>
