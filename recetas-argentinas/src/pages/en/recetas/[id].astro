---
import Layout from '../../../layouts/Layout.astro';
import { recipes } from '../../../data/recipes';

// Generate dynamic routes for en locale
export function getStaticPaths() {
    return recipes.map(recipe => ({
        params: { id: recipe.id },
        props: { recipe },
    }));
}

const { recipe } = Astro.props;
const data = recipe.en;
---

<Layout title={`${data.title} | Argentine Flavor`} lang="en">
    <article class="recipe-detail">
        <a href="/en" class="back-link">← Back to recipes</a>
        
        <header class="detail-hero">
            <div class="image-container">
                <img src={recipe.image} alt={data.title} transition:name={`img-${recipe.id}`} />
                <div class="overlay"></div>
            </div>
            <div class="hero-content">
                <h1 transition:name={`title-${recipe.id}`}>{data.title}</h1>
                <p class="description">{data.description}</p>
                <div class="badges">
                    <span class="badge">⏱ {data.time}</span>
                    <span class="badge">🔥 {data.difficulty}</span>
                </div>
            </div>
        </header>

        <section class="recipe-body">
            <div class="ingredients">
                <h2>Ingredients</h2>
                <ul>
                    {data.ingredients.map((ingredient: string) => (
                        <li>{ingredient}</li>
                    ))}
                </ul>
            </div>

            <div class="instructions">
                <h2>Preparation</h2>
                <ol>
                    {data.steps.map((step: string) => (
                        <li>{step}</li>
                    ))}
                </ol>
            </div>
        </section>
    </article>
</Layout>

<style>
    .recipe-detail {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1rem 6rem;
		animation: fadeIn 0.8s ease-out forwards;
    }

    .back-link {
        display: inline-block;
        color: var(--primary);
        text-decoration: none;
        margin-bottom: 2rem;
        font-weight: 600;
        transition: color 0.3s ease;
    }

    .back-link:hover {
        color: #ffffff;
    }

    .detail-hero {
        position: relative;
        border-radius: 20px;
        overflow: hidden;
        margin-bottom: 4rem;
        box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    }

    .image-container {
        position: relative;
        width: 100%;
        height: 450px;
    }

    .image-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(10, 15, 22, 1) 0%, rgba(10, 15, 22, 0) 100%);
    }

    .hero-content {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 3rem;
    }

    h1 {
        font-size: 3.5rem;
        font-weight: 800;
        color: #ffffff;
        margin-bottom: 1rem;
        text-shadow: 0px 4px 10px rgba(0,0,0,0.4);
    }

    .description {
        font-size: 1.15rem;
        color: #e2e8f0;
        max-width: 700px;
        margin-bottom: 2rem;
        line-height: 1.6;
        text-shadow: 0 1px 3px rgba(0,0,0,0.8);
    }

    .badges {
        display: flex;
        gap: 1rem;
    }

    .badge {
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(10px);
        padding: 0.5rem 1rem;
        border-radius: 100px;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--secondary);
		border: 1px solid rgba(255,255,255,0.1);
    }

    .recipe-body {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 4rem;
    }

    h2 {
        font-size: 2rem;
        color: var(--primary);
        margin-bottom: 1.5rem;
        font-weight: 600;
    }

    ul {
        list-style: none;
        background: var(--card-bg);
        padding: 2rem;
        border-radius: 15px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    ul li {
        position: relative;
        padding-left: 1.5rem;
        margin-bottom: 1rem;
        color: var(--text-main);
        line-height: 1.6;
        font-size: 1.05rem;
    }

    ul li:last-child {
        margin-bottom: 0;
    }

    ul li::before {
        content: "🔪";
        position: absolute;
        left: 0;
        font-size: 1rem;
        line-height: 1.6;
    }

    ol {
        list-style: none;
        counter-reset: steps;
    }

    ol li {
        position: relative;
        padding-left: 4.5rem;
        margin-bottom: 2.5rem;
        color: var(--text-main);
        line-height: 1.7;
        font-size: 1.1rem;
    }

    ol li::before {
        counter-increment: steps;
        content: counter(steps);
        position: absolute;
        left: 0;
        top: -6px;
        width: 3rem;
        height: 3rem;
        background: rgba(91, 192, 235, 0.1);
        border: 1px solid var(--primary);
        color: var(--primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.2rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 900px) {
        .recipe-body {
            grid-template-columns: 1fr;
            gap: 3rem;
        }

        h1 {
            font-size: 2.5rem;
        }

        .hero-content {
            padding: 2rem;
        }

        .image-container {
            height: 350px;
        }
    }
</style>
